WORLDPANEL_EMAIL=your.email@example.com
WORLDPANEL_PASSWORD=change-me
WORLDPANEL_REPORT_SET=CN - Zespri - CS
WORLDPANEL_HEADLESS=true
WORLDPANEL_TIMEOUT_MS=60000

# Server-side AI planner (LLM-first). Defaults target Doubao (Volcano Ark), so
# you only need to set the API key for the model to become the default
# recognizer. Leave the key blank to use rule-based recognition only.
# NEVER commit a real key — this repo is public.
WPO_AI_API_KEY=
# Optional overrides (defaults shown) — change only to use another provider:
# WPO_AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
# WPO_AI_MODEL=ep-20260611143619-l7n26
# WPO_AI_PROVIDER=doubao
