WORLDPANEL_EMAIL=your.email@example.com
WORLDPANEL_PASSWORD=change-me
WORLDPANEL_REPORT_SET=CN - Zespri - CS
WORLDPANEL_HEADLESS=true
WORLDPANEL_TIMEOUT_MS=60000

# Server-side AI planner (LLM-first). When set, the app maps natural-language
# questions to the live schema with the model and only falls back to rule-based
# recognition if the call fails. WPO_AI_BASE_URL is the full chat-completions
# endpoint (e.g. https://api.openai.com/v1/chat/completions). Leave blank for
# rules only.
WPO_AI_BASE_URL=
WPO_AI_MODEL=
WPO_AI_API_KEY=
WPO_AI_PROVIDER=custom
